share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
#  Usually these files are written by a python script, and contain the bin/
#  and lib directories for a python project, which are usually not under
#  control-source.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

